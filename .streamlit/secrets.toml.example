# CTI War Room — secrets template.
# Copy this file to ".streamlit/secrets.toml" and fill in real keys.
#   copy .streamlit\secrets.toml.example .streamlit\secrets.toml   (Windows)
#
# Every key is OPTIONAL. The app boots without a secrets file; each missing key
# simply disables that capability (the sidebar shows which are missing).
# NOTE: .streamlit/secrets.toml is git-ignored — never commit real keys.

groq_key      = ""   # Groq API (Llama 3.3 70B) — AI summaries & IOC verdicts | https://console.groq.com
vt_key        = ""   # VirusTotal API v3 — IOC reputation                     | https://www.virustotal.com
urlscan_key   = ""   # urlscan.io API — URL scanning                          | https://urlscan.io
abuseipdb_key = ""   # AbuseIPDB API — IP reputation                          | https://www.abuseipdb.com
